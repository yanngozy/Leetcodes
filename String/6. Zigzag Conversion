def convert(self, s, numRows):
       
        if numRows == 1:
            return s

        n = len(s)
        arr = [[""] for i in range(numRows)]
        c = 0
        while c<n:
            i = 0
            while i<numRows-1 and c<n:
                arr[i].append(s[c])
                c += 1
                i += 1

            while i>0 and c<n:
                arr[i].append(s[c])
                c +=1
                i -= 1

        res = ""
        for i in range(numRows):
            res += "".join(arr[i])

        return res

# space and time complexity O(n)
