def compress(chars):
      n=len(chars)
      j=0  # pointer to the beginning of the current sequence
      count=0 # length of the compressed string
      for i in range(1,n):
          if chars[i]!=chars[j]: # end of the sequence 
              if i-j>1:
                  s=str(i-j)
                  for k in range(len(s)):
                      chars[count+k+1]=s[k]
                  count+=len(s)+1
              else:
                  count+=1
              j=i
              chars[count]=chars[i]

      if j==n-1: # add the last sequence
          return count+1
      else:
          s=str(n-j)
          for k in range(len(s)):
              chars[count+k+1]=s[k]
        
          return count+len(s)+1

      
        
