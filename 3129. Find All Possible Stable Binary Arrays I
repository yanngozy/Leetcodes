def numberOfStableArrays(zero, one, limit):
  mod=10**9+7
  dp1=[[0 for i in range(zero+1)] for j in range(one+1)]
  dp2=[[0 for i in range(zero+1)] for j in range(one+1)]
  for l in range(1,limit+1):
      dp1[min(l,one)][0]=1
      dp2[0][min(l,zero)]=1
  for i in range(1,one+1):
      for j in range(1,zero+1):
          dp1[i][j]=dp2[i-1][j]
          dp2[i][j]=dp1[i][j-1]
          if i>limit:
              dp1[i][j]=(dp1[i][j]+dp1[i-1][j]-dp2[i-1-limit][j])%mod
          elif i>1:
              dp1[i][j]=(dp1[i][j]+dp1[i-1][j])%mod
          if j-1>=limit:
              dp2[i][j]=(dp2[i][j]+dp2[i][j-1]-dp1[i][j-1-limit])%mod
          elif j>1:
              dp2[i][j]=(dp2[i][j]+dp2[i][j-1])%mod
  return (dp1[one][zero]+dp2[one][zero])%mod

        
