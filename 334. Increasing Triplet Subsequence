def increasingTriplet(self, nums):
      
      n=len(nums)
      right=[False]*n # determine if we can find a greater number than the current in the right side of the array
      M=nums[-1]
      for i in range(n-2,-1,-1):
          if nums[i]<M:
              right[i]=True
          else:
              M=nums[i]
      index=0
      for i in range(1,len(nums)):
          if nums[i]>nums[index] and right[i]:
              return True   
          elif nums[i]<nums[index]:
              index=i
      return False
        
