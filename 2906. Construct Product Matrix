 def productMatrix(grid):
        n = len(grid)
        m = len(grid[0])
        MOD = 12345
        p = [[0] * m for _ in range(n)]
        current_product = 1
        for i in range(n):
            for j in range(m):
                p[i][j] = current_product
                current_product = (current_product * grid[i][j]) % MOD
                
        current_product = 1
        for i in range(n - 1, -1, -1):
            for j in range(m - 1, -1, -1):
                p[i][j] = (p[i][j] * current_product) % MOD
                current_product = (current_product * grid[i][j]) % MOD
                
        return p
