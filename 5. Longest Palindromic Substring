def longestPalindrome(s):
    """
        Dynamic programming: S[i:j] is a palindrome if S[i]=S[j] and S[i+1:j-1] is a palindrome
        return: the longest palindrome in S
    """

    n=len(s)
    is_palindrome=[[False]*(i+1) for i in range(n)]
    res=s[0]
    length=1
    for i in range(n):
        is_palindrome[i][i]=True
    for i in range(1,n):
        if s[i]==s[i-1]:
            is_palindrome[i][i-1]=True
            if length<2:
                length,res=2, s[i-1]+s[i]
        for j in range(i-2,-1,-1):
            if is_palindrome[i-1][j+1] and s[i]==s[j]:
                is_palindrome[i][j]=True
                if length<i-j+1:
                    length,res=i-j+1, s[j:i+1]
      return res
