def getPermutation( n, k):
        if n==1:
            return "1"
        facto=[1,1]
        for i in range(2,n):
            facto.append(facto[-1]*i)
        res=""
        nums=[i for i in range(1,n+1)]
        for i in range(1,n+1):
            d=int((k-1)/facto[n-i])
            res+=str(nums[d])
            k-=d*facto[n-i]
            nums.remove(nums[d])
        return res
